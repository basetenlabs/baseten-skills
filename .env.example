# Copy to .env (gitignored) and fill in. Used by `evals` runner.
# Test workspace key — never use a production key here.
BASETEN_MCP_KEY=
ANTHROPIC_API_KEY=

# OPTIONAL: route Claude Code at Baseten's OpenAI-compatible inference proxy
# instead of Anthropic. Uncomment and set BASETEN_API_KEY (separate from
# BASETEN_MCP_KEY). Pick any model exposed by your workspace.
# ANTHROPIC_BASE_URL=https://inference.baseten.co
# ANTHROPIC_AUTH_TOKEN=${BASETEN_API_KEY}
# ANTHROPIC_MODEL=MiniMaxAI/MiniMax-M2.5
# ANTHROPIC_SMALL_FAST_MODEL=MiniMaxAI/MiniMax-M2.5
